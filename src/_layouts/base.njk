<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}AceApp 工具合集</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%);
            min-height: 100vh;
            color: #333;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }
        
        .header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            font-weight: 700;
        }
        
        .header p {
            font-size: 1.1rem;
            opacity: 1;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
            font-weight: 500;
        }
        
        .search-section {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        
        .search-box {
            position: relative;
            margin-bottom: 20px;
        }
        
        .search-input {
            width: 100%;
            padding: 15px 50px 15px 20px;
            border: 2px solid #e1e5e9;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s ease;
        }
        
        .search-input:focus {
            outline: none;
            border-color: #4682B4;
            box-shadow: 0 0 0 3px rgba(70, 130, 180, 0.1);
        }
        
        .search-icon {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
        }
        
        .filters {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: center;
        }
        
        .filter-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .filter-label {
            font-weight: 600;
            color: #495057;
        }
        
        .filter-select {
            padding: 8px 12px;
            border: 2px solid #e1e5e9;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .filter-select:focus {
            outline: none;
            border-color: #4682B4;
        }
        
        .stats {
            background: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-top: 15px;
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #4682B4;
        }
        
        .stat-label {
            color: #6c757d;
            margin-top: 5px;
        }
        
        .tools-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .tool-card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        
        .tool-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        }
        
        .tool-card.featured {
            border: 2px solid #4682B4;
        }
        
        .featured-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #4682B4;
            color: white;
            padding: 4px 8px;
            border-radius: 5px;
            font-size: 0.75rem;
            font-weight: bold;
        }
        
        .tool-content {
            flex: 1;
        }
        
        .tool-title {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 10px;
            color: #2c3e50;
        }
        
        .tool-description {
            color: #6c757d;
            margin-bottom: 15px;
            line-height: 1.5;
        }
        
        .tool-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            font-size: 0.9rem;
            color: #868e96;
        }
        
        .tool-category {
            background: #e9ecef;
            padding: 4px 8px;
            border-radius: 5px;
            font-size: 0.8rem;
        }
        
        .tool-tags {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            margin-bottom: 15px;
        }
        
        .tag {
            background: #f8f9fa;
            color: #495057;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            border: 1px solid #dee2e6;
        }
        
        .tool-link {
            display: inline-block;
            background: #4682B4;
            color: white;
            padding: 8px 16px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            align-self: flex-end;
        }
        
        .tool-link:hover {
            background: #5A9FD4;
            transform: translateY(-1px);
        }
        
        .no-results {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .no-results h2 {
            color: #6c757d;
            margin-bottom: 10px;
        }
        
        .no-results p {
            color: #868e96;
        }
        
        @media (max-width: 768px) {
            .header h1 {
                font-size: 2rem;
            }
            
            .tools-grid {
                grid-template-columns: 1fr;
            }
            
            .filters {
                flex-direction: column;
                align-items: stretch;
            }
            
            .filter-group {
                justify-content: space-between;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header class="header">
            <h1>AceApp 工具合集</h1>
            <p>精选实用工具，提升工作效率</p>
        </header>
        
        {% block content %}{% endblock %}
    </div>
    
    <script>
        // 搜索功能
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('search');
            const categorySelect = document.getElementById('category');
            const tagSelect = document.getElementById('tag');
            
            if (searchInput && categorySelect && tagSelect) {
                function performSearch() {
                    const query = searchInput.value.toLowerCase();
                    const category = categorySelect.value;
                    const tag = tagSelect.value;
                    
                    const toolCards = document.querySelectorAll('.tool-card');
                    
                    toolCards.forEach(card => {
                        const title = card.querySelector('.tool-title').textContent.toLowerCase();
                        const description = card.querySelector('.tool-description')?.textContent.toLowerCase() || '';
                        const cardCategory = card.querySelector('.tool-category').textContent;
                        const tags = Array.from(card.querySelectorAll('.tag')).map(tag => tag.textContent);
                        
                        let matches = true;
                        
                        // 搜索匹配
                        if (query && !title.includes(query) && !description.includes(query)) {
                            matches = false;
                        }
                        
                        // 分类匹配
                        if (category && category !== '全部' && cardCategory !== category) {
                            matches = false;
                        }
                        
                        // 标签匹配
                        if (tag && tag !== '全部' && !tags.includes(tag)) {
                            matches = false;
                        }
                        
                        card.style.display = matches ? 'flex' : 'none';
                    });
                    
                    // 更新统计
                    updateStats();
                }
                
                function updateStats() {
                    const visibleCards = document.querySelectorAll('.tool-card:not([style*="display: none"])');
                    const totalCount = document.querySelectorAll('.tool-card').length;
                    const statNumber = document.querySelector('.stat-number');
                    if (statNumber) {
                        statNumber.textContent = visibleCards.length;
                    }
                }
                
                searchInput.addEventListener('input', debounce(performSearch, 300));
                categorySelect.addEventListener('change', performSearch);
                tagSelect.addEventListener('change', performSearch);
            }
        });
        
        function debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                const later = () => {
                    clearTimeout(timeout);
                    func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        }
    </script>
</body>
</html>
