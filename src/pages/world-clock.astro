---
import ToolLayout from '../layouts/ToolLayout.astro';
import { TOOLS } from '../data/tools.js';

const tool = TOOLS.find((t) => t.id === 'world-clock');
---
<ToolLayout tool={tool}>
  <div class="wc">
    <div class="wc-bar">
      <div class="wc-combo" id="wc-combo">
        <input type="text" class="field" id="wc-input" role="combobox" aria-expanded="false" aria-autocomplete="list" placeholder="Add a clock — type an offset like +6 or -5" autocomplete="off" />
        <div class="wc-options" id="wc-options" role="listbox" hidden></div>
      </div>
      <label class="wc-toggle"><input type="checkbox" id="wc-hour12" /> 12-hour</label>
    </div>

    <div class="wc-grid" id="wc-grid"></div>
    <p class="wc-empty" id="wc-empty" hidden>No clocks yet. Add a UTC offset above.</p>
  </div>
</ToolLayout>

<style>
  .wc { display: flex; flex-direction: column; gap: 20px; }
  .wc-bar { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px; }
  .wc-toggle { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: var(--muted); white-space: nowrap; }

  /* Searchable dropdown */
  .wc-combo { position: relative; flex: 1 1 320px; min-width: 240px; max-width: 420px; }
  .wc-options {
    position: absolute; left: 0; right: 0; top: calc(100% + 6px); z-index: 30;
    max-height: 280px; overflow-y: auto;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: var(--radius-lg); box-shadow: rgba(0, 0, 0, 0.1) 0 4px 12px;
    padding: 6px;
  }
  .wc-opt {
    display: flex; align-items: baseline; gap: 10px;
    width: 100%; text-align: left; cursor: pointer;
    background: transparent; border: none; border-radius: var(--radius);
    padding: 9px 12px; font-size: 14px; color: var(--fg); font-family: var(--mono);
  }
  .wc-opt:hover, .wc-opt.active { background: var(--subtle); }
  .wc-opt .ex { color: var(--muted); font-family: var(--font); font-size: 12px; margin-left: auto; }
  .wc-none { padding: 12px; color: var(--muted); font-size: 13px; text-align: center; }

  /* Clock cards */
  .wc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 16px; }
  .wc-card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--bg), var(--subtle-2));
    padding: 18px 20px 20px;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .wc-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .wc-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .wc-badge {
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    color: var(--fg); background: var(--subtle);
    border: 1px solid var(--border); border-radius: 9999px; padding: 3px 10px;
  }
  .wc-remove {
    width: 24px; height: 24px; border-radius: 6px;
    border: none; background: transparent; color: var(--muted);
    cursor: pointer; font-size: 16px; line-height: 1;
    opacity: 0; transition: opacity 0.15s ease;
  }
  .wc-card:hover .wc-remove, .wc-remove:focus { opacity: 1; }
  .wc-remove:hover { background: var(--subtle); color: var(--fg); }
  .wc-time {
    font-family: var(--mono); font-weight: 600;
    font-size: clamp(30px, 6vw, 38px); line-height: 1.05; letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums; display: flex; align-items: baseline; gap: 6px;
  }
  .wc-ampm { font-size: 14px; font-weight: 500; color: var(--muted); }
  .wc-date { font-size: 13px; color: var(--muted); margin-top: 8px; }
  .wc-empty { text-align: center; color: var(--muted); padding: 56px 24px; margin: 0; border: 1px dashed var(--border); border-radius: var(--radius-lg); }
</style>

<script>
  // World Clock — live clocks for fixed UTC offsets, saved in localStorage.
  // Offsets are DST-free by design (a clock is just "UTC + N minutes").
  const KEY = 'world-clock.v2';

  // Real-world UTC offsets in minutes, from -12:00 to +14:00.
  const OFFSETS = [
    -720, -660, -600, -570, -540, -480, -420, -360, -300, -240, -210, -180,
    -120, -60, 0, 60, 120, 180, 210, 240, 270, 300, 330, 345, 360, 390, 420,
    480, 525, 540, 570, 600, 630, 660, 720, 765, 780, 840,
  ];

  const $ = (id) => document.getElementById(id);
  const grid = $('wc-grid');
  const emptyEl = $('wc-empty');
  const input = $('wc-input');
  const optionsEl = $('wc-options');
  const hour12El = $('wc-hour12');

  // { offsets: number[] (minutes), hour12: boolean }
  let state = load();

  function load() {
    try {
      const p = JSON.parse(localStorage.getItem(KEY) || '');
      if (p && Array.isArray(p.offsets)) return { offsets: p.offsets, hour12: !!p.hour12 };
    } catch { /* ignore */ }
    return { offsets: [0], hour12: false }; // default: UTC
  }
  function save() {
    try { localStorage.setItem(KEY, JSON.stringify(state)); } catch { /* private mode */ }
  }

  function label(min) {
    if (min === 0) return 'UTC';
    const sign = min < 0 ? '−' : '+';
    const a = Math.abs(min), h = Math.floor(a / 60), m = a % 60;
    return 'UTC' + sign + h + (m ? ':' + String(m).padStart(2, '0') : '');
  }
  // Plain-ASCII search text (uses '-' not '−') so typing "-5" matches.
  function searchText(min) {
    if (min === 0) return 'utc utc+0 0';
    const sign = min < 0 ? '-' : '+';
    const a = Math.abs(min), h = Math.floor(a / 60), m = a % 60;
    return ('utc' + sign + h + (m ? ':' + String(m).padStart(2, '0') : '')).toLowerCase();
  }

  // --- searchable dropdown ---
  let visible = [];   // currently shown offset list
  let active = -1;    // highlighted index

  function openList() { renderList(input.value); optionsEl.hidden = false; input.setAttribute('aria-expanded', 'true'); }
  function closeList() { optionsEl.hidden = true; input.setAttribute('aria-expanded', 'false'); active = -1; }

  function renderList(q) {
    const qq = q.trim().toLowerCase().replace('−', '-');
    visible = OFFSETS.filter((min) => !state.offsets.includes(min) && (qq === '' || searchText(min).includes(qq)));
    active = visible.length ? 0 : -1;
    optionsEl.textContent = '';
    if (!visible.length) {
      const none = document.createElement('div');
      none.className = 'wc-none';
      none.textContent = 'No matching offset.';
      optionsEl.appendChild(none);
      return;
    }
    visible.forEach((min, i) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'wc-opt' + (i === active ? ' active' : '');
      b.setAttribute('role', 'option');
      const name = document.createElement('span');
      name.textContent = label(min);
      b.appendChild(name);
      b.addEventListener('mousedown', (e) => { e.preventDefault(); addOffset(min); });
      optionsEl.appendChild(b);
    });
  }

  function setActive(i) {
    const btns = optionsEl.querySelectorAll('.wc-opt');
    if (!btns.length) return;
    active = (i + btns.length) % btns.length;
    btns.forEach((b, idx) => b.classList.toggle('active', idx === active));
    btns[active].scrollIntoView({ block: 'nearest' });
  }

  input.addEventListener('focus', openList);
  input.addEventListener('input', () => { openList(); });
  input.addEventListener('keydown', (e) => {
    if (optionsEl.hidden && (e.key === 'ArrowDown' || e.key === 'ArrowUp')) { openList(); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
    else if (e.key === 'Enter') { e.preventDefault(); if (active >= 0 && visible[active] !== undefined) addOffset(visible[active]); }
    else if (e.key === 'Escape') { closeList(); }
  });
  document.addEventListener('click', (e) => {
    if (!$('wc-combo').contains(e.target)) closeList();
  });

  // --- formatters (all in UTC; the offset is baked into the Date we pass) ---
  let timeFmt, dateFmt;
  function buildFormatters() {
    timeFmt = new Intl.DateTimeFormat('en-GB', {
      timeZone: 'UTC', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: state.hour12,
    });
    dateFmt = new Intl.DateTimeFormat('en-GB', {
      timeZone: 'UTC', weekday: 'short', month: 'short', day: 'numeric',
    });
  }
  buildFormatters();

  // --- clock cards ---
  let refs = new Map(); // offset -> { timeEl, ampmEl, dateEl }

  function renderCards() {
    grid.textContent = '';
    refs = new Map();
    emptyEl.hidden = state.offsets.length > 0;

    for (const min of state.offsets) {
      const card = document.createElement('div');
      card.className = 'wc-card';

      const top = document.createElement('div');
      top.className = 'wc-card-top';
      const badge = document.createElement('span');
      badge.className = 'wc-badge';
      badge.textContent = label(min);
      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'wc-remove';
      remove.setAttribute('aria-label', 'Remove ' + label(min));
      remove.textContent = '×';
      remove.addEventListener('click', () => removeOffset(min));
      top.append(badge, remove);

      const timeEl = document.createElement('div');
      timeEl.className = 'wc-time';
      const hhmmss = document.createElement('span');
      const ampmEl = document.createElement('span');
      ampmEl.className = 'wc-ampm';
      timeEl.append(hhmmss, ampmEl);

      const dateEl = document.createElement('div');
      dateEl.className = 'wc-date';

      card.append(top, timeEl, dateEl);
      grid.appendChild(card);
      refs.set(min, { hhmmss, ampmEl, dateEl });
    }
    tick();
  }

  function tick() {
    const nowMs = Date.now();
    for (const [min, r] of refs) {
      const d = new Date(nowMs + min * 60000);
      if (state.hour12) {
        const parts = timeFmt.formatToParts(d);
        const t = parts.filter((p) => p.type !== 'dayPeriod').map((p) => p.value).join('').trim();
        const ap = parts.find((p) => p.type === 'dayPeriod');
        r.hhmmss.textContent = t;
        r.ampmEl.textContent = ap ? ap.value.toUpperCase() : '';
      } else {
        r.hhmmss.textContent = timeFmt.format(d);
        r.ampmEl.textContent = '';
      }
      r.dateEl.textContent = dateFmt.format(d);
    }
  }

  function addOffset(min) {
    if (!state.offsets.includes(min)) {
      state.offsets.push(min);
      state.offsets.sort((a, b) => a - b);
      save();
      renderCards();
    }
    input.value = '';
    closeList();
  }
  function removeOffset(min) {
    state.offsets = state.offsets.filter((x) => x !== min);
    save();
    renderCards();
  }

  hour12El.checked = state.hour12;
  hour12El.addEventListener('change', () => {
    state.hour12 = hour12El.checked;
    save();
    buildFormatters();
    tick();
  });

  renderCards();
  setInterval(tick, 1000);
</script>
