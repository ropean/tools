---
import ToolLayout from '../layouts/ToolLayout.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import { TOOLS } from '../data/tools.js';

// Placeholder pages for planned tools. Live tools (ready:true) have their own
// native page at src/pages/<id>.astro instead.
export function getStaticPaths() {
  return TOOLS.filter((t) => !t.ready).map((tool) => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;
---
<ToolLayout tool={tool}>
  <div class="placeholder">
    <span class="card-icon" style="width:48px;height:48px;border-radius:12px;margin:0 auto 16px;"><CategoryIcon category={tool.category} size={22} /></span>
    <h3>{tool.name}</h3>
    <p>{tool.desc}</p>
    <div style="max-width:360px;margin:0 auto;display:flex;flex-direction:column;gap:10px;opacity:0.5;pointer-events:none;">
      <div style="height:38px;border-radius:6px;border:1px solid var(--border);background:var(--bg);"></div>
      <div style="height:38px;border-radius:6px;background:var(--dark);"></div>
    </div>
    <p style="margin-top:20px;">This tool is under construction. Meanwhile, browse the <a href="/" style="color:var(--fg);text-decoration:underline;">tools that are already live</a>.</p>
  </div>
</ToolLayout>
