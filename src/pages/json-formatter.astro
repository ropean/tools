---
import ToolLayout from '../layouts/ToolLayout.astro';
import { TOOLS } from '../data/tools.js';

const tool = TOOLS.find((t) => t.id === 'json-formatter');
---
<ToolLayout tool={tool}>
  <div class="jf">
    <div class="jf-toolbar">
      <button type="button" class="btn btn-primary" id="jf-format">Format</button>
      <button type="button" class="btn" id="jf-minify">Minify</button>
      <button type="button" class="btn" id="jf-clear">Clear</button>
      <label class="jf-indent">
        Indent
        <select class="field" id="jf-indent">
          <option value="2" selected>2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <button type="button" class="btn" id="jf-copy" style="margin-left:auto;">Copy</button>
    </div>

    <div class="jf-search">
      <div class="jf-search-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5f5f5d" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
        <input type="text" class="field" id="jf-q" placeholder="Search in output… (Enter next, Shift+Enter previous)" autocomplete="off" />
      </div>
      <label class="jf-case"><input type="checkbox" id="jf-case" /> Case sensitive</label>
      <span class="jf-count" id="jf-count" aria-live="polite"></span>
      <button type="button" class="btn" id="jf-prev" aria-label="Previous match" disabled>↑</button>
      <button type="button" class="btn" id="jf-next" aria-label="Next match" disabled>↓</button>
    </div>

    <div class="jf-panes">
      <div class="jf-pane">
        <span class="jf-label">Input</span>
        <textarea class="field mono" id="jf-in" spellcheck="false" placeholder="Paste JSON here, then press Format (or Ctrl/Cmd+Enter)."></textarea>
      </div>
      <div class="jf-pane">
        <span class="jf-label">Output</span>
        <textarea class="field mono" id="jf-out" spellcheck="false" readonly placeholder="Formatted JSON appears here."></textarea>
      </div>
    </div>

    <p class="jf-msg" id="jf-msg" hidden></p>
  </div>
</ToolLayout>

<style>
  .jf { display: flex; flex-direction: column; gap: 14px; }
  .jf-toolbar { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
  .jf-indent { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); }
  .jf-indent .field { width: auto; padding: 6px 10px; font-size: 13px; }

  .jf-search { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
  .jf-search-box { position: relative; flex: 1 1 280px; min-width: 220px; }
  .jf-search-box svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); pointer-events: none; }
  .jf-search-box .field { padding-left: 38px; }
  .jf-case { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); white-space: nowrap; }
  .jf-count { font-size: 13px; color: var(--muted); min-width: 72px; text-align: right; font-variant-numeric: tabular-nums; }

  .jf-panes { display: flex; flex-wrap: wrap; gap: 16px; }
  .jf-pane { flex: 1 1 320px; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
  .jf-label { font-size: 12px; color: var(--muted); }
  .jf-panes textarea { min-height: 420px; }

  .jf-msg { margin: 0; font-size: 13px; }
  .jf-msg.error { color: var(--error); }
  .jf-msg.ok { color: var(--muted); }
</style>

<script>
  // JSON Formatter with keyword search.
  //
  // Performance notes:
  //  - Output lives in a <textarea>, not a highlighted DOM tree, so multi-MB JSON
  //    renders instantly and never builds tens of thousands of <mark> nodes.
  //  - Search scans the string with indexOf (O(n)), is debounced, and caps the
  //    match list; navigation selects + scrolls the textarea to each hit.
  const $ = (id) => document.getElementById(id);
  const inEl = $('jf-in');
  const outEl = $('jf-out');
  const qEl = $('jf-q');
  const caseEl = $('jf-case');
  const countEl = $('jf-count');
  const prevBtn = $('jf-prev');
  const nextBtn = $('jf-next');
  const msgEl = $('jf-msg');

  const MAX_MATCHES = 20000; // safety cap for pathological queries

  let matches = []; // start indices in outEl.value
  let capped = false;
  let current = -1;

  function setMsg(text, kind) {
    if (!text) { msgEl.hidden = true; msgEl.textContent = ''; return; }
    msgEl.hidden = false;
    msgEl.textContent = text;
    msgEl.className = 'jf-msg ' + (kind || '');
  }

  function indentValue() {
    const v = $('jf-indent').value;
    return v === 'tab' ? '\t' : Number(v);
  }

  function parseInput() {
    const raw = inEl.value.trim();
    if (!raw) { outEl.value = ''; setMsg('', ''); return undefined; }
    try {
      return JSON.parse(raw);
    } catch (err) {
      setMsg('Invalid JSON: ' + err.message, 'error');
      return undefined;
    }
  }

  function format() {
    const data = parseInput();
    if (data === undefined) return;
    outEl.value = JSON.stringify(data, null, indentValue());
    setMsg('Valid JSON · ' + outEl.value.length.toLocaleString() + ' chars', 'ok');
    runSearch();
  }

  function minify() {
    const data = parseInput();
    if (data === undefined) return;
    outEl.value = JSON.stringify(data);
    setMsg('Minified · ' + outEl.value.length.toLocaleString() + ' chars', 'ok');
    runSearch();
  }

  function clearAll() {
    inEl.value = '';
    outEl.value = '';
    setMsg('', '');
    runSearch();
    inEl.focus();
  }

  // --- search ---
  function computeMatches() {
    matches = [];
    capped = false;
    const needle = qEl.value;
    if (!needle) return;

    const cs = caseEl.checked;
    const hay = cs ? outEl.value : outEl.value.toLowerCase();
    const find = cs ? needle : needle.toLowerCase();
    const step = find.length || 1;

    let i = hay.indexOf(find);
    while (i !== -1) {
      matches.push(i);
      if (matches.length >= MAX_MATCHES) { capped = true; break; }
      i = hay.indexOf(find, i + step);
    }
  }

  function renderCount() {
    const has = matches.length > 0;
    prevBtn.disabled = !has;
    nextBtn.disabled = !has;
    if (!qEl.value) { countEl.textContent = ''; return; }
    if (!has) { countEl.textContent = 'No matches'; return; }
    const total = matches.length + (capped ? '+' : '');
    countEl.textContent = (current + 1) + ' / ' + total;
  }

  function scrollToSelection(start) {
    // Approximate the line and center it (textarea can't be queried for caret px).
    const line = outEl.value.slice(0, start).split('\n').length - 1;
    const lh = parseFloat(getComputedStyle(outEl).lineHeight) || 18;
    outEl.scrollTop = Math.max(0, line * lh - outEl.clientHeight / 2);
  }

  function goTo(index) {
    if (!matches.length) return;
    current = (index + matches.length) % matches.length;
    const start = matches[current];
    const end = start + qEl.value.length;
    outEl.focus();
    outEl.setSelectionRange(start, end);
    scrollToSelection(start);
    renderCount();
  }

  function runSearch() {
    computeMatches();
    current = matches.length ? 0 : -1;
    renderCount();
    if (current === 0) goTo(0);
  }

  // Debounce search-as-you-type so large output isn't rescanned on every keystroke.
  let t;
  function debouncedSearch() {
    clearTimeout(t);
    t = setTimeout(runSearch, 180);
  }

  $('jf-format').addEventListener('click', format);
  $('jf-minify').addEventListener('click', minify);
  $('jf-clear').addEventListener('click', clearAll);
  $('jf-indent').addEventListener('change', () => { if (outEl.value) format(); });

  $('jf-copy').addEventListener('click', async () => {
    if (!outEl.value) return;
    await navigator.clipboard.writeText(outEl.value);
    const btn = $('jf-copy');
    const prev = btn.textContent;
    btn.textContent = 'Copied';
    setTimeout(() => { btn.textContent = prev; }, 1200);
  });

  qEl.addEventListener('input', debouncedSearch);
  caseEl.addEventListener('change', runSearch);
  qEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); e.shiftKey ? goTo(current - 1) : goTo(current + 1); }
  });
  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  // Ctrl/Cmd+Enter formats from the input box.
  inEl.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); format(); }
  });
</script>
