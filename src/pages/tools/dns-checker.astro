---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { TOOLS } from '../../data/tools.js';

const tool = TOOLS.find((t) => t.id === 'dns-checker');
---
<ToolLayout tool={tool}>
  <div class="dns">
    <p class="dns-subtitle">Upload a DNS records file to check the HTTPS status code of each host one by one.</p>

    <div class="dns-upload" id="dropZone">
      <label class="dns-upload-label" for="fileInput">
        Drag a file here, or <span>click to select a file</span>
      </label>
      <input type="file" id="fileInput" accept=".txt,.csv,.zone,text/*" />
    </div>

    <div class="dns-actions">
      <button type="button" class="btn btn-primary" id="startBtn" disabled>Start check</button>
      <button type="button" class="btn" id="clearBtn">Clear</button>
      <span class="dns-progress" id="progress"></span>
    </div>

    <p class="dns-notice">
      Requests are proxied through <a href="https://api.ropean.org">api.ropean.org</a>
      with allowRedirect=false; redirects only show the first status code.
    </p>

    <div class="dns-filter-bar" id="filterBar"></div>

    <div class="dns-table-wrap">
      <table id="resultTable">
        <thead>
          <tr>
            <th class="cb-col"><input type="checkbox" id="checkAll" checked title="Select/deselect all" /></th>
            <th>#</th>
            <th>Host</th>
            <th>URL</th>
            <th>Status</th>
            <th>Mark</th>
            <th>Retry</th>
          </tr>
        </thead>
        <tbody id="resultBody"></tbody>
      </table>
    </div>
  </div>
</ToolLayout>

<style>
  .dns { display: flex; flex-direction: column; gap: 16px; }
  .dns-subtitle { font-size: 14px; color: var(--muted); margin: 0; }

  .dns-upload {
    border: 2px dashed var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 32px;
    text-align: center;
    cursor: pointer;
    background: var(--subtle-2);
    transition: border-color 0.2s, background 0.2s;
  }
  .dns-upload:hover, .dns-upload.drag-over { border-color: var(--ring-border); background: var(--subtle); }
  .dns-upload input[type=file] { display: none; }
  .dns-upload-label { font-size: 15px; color: var(--muted); cursor: pointer; }
  .dns-upload-label span { color: var(--fg); text-decoration: underline; }

  .dns-actions { display: flex; gap: 8px; align-items: center; }
  .dns-progress { font-size: 13px; color: var(--muted); margin-left: auto; }

  .dns-notice { font-size: 12px; color: var(--muted); margin: 0; }
  .dns-notice a { color: var(--muted); }

  /* Filter bar */
  .dns-filter-bar { display: flex; gap: 6px; flex-wrap: wrap; min-height: 0; }
  .fpill {
    font-size: 12px; font-weight: 500;
    padding: 3px 10px; border-radius: 9999px; border: 1.5px solid currentColor;
    cursor: pointer; background: transparent; transition: background 0.15s, color 0.15s;
    opacity: 0.55;
  }
  .fpill.active { opacity: 1; background: currentColor; }
  .fpill.active span { color: var(--on-dark); }
  .fpill span { display: inline; }
  .fpill-all { color: var(--muted); }
  .fpill-2xx { color: #2f7d4f; }
  .fpill-208 { color: #1f7a8c; }
  .fpill-3xx { color: #b06f2b; }
  .fpill-4xx { color: #9a3b2e; }
  .fpill-5xx { color: #7a2820; }
  .fpill-err { color: var(--border-strong); }

  /* Table */
  .dns-table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
  thead th {
    background: var(--subtle); font-size: 11px; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.05em; padding: 10px 14px;
    text-align: left; border-bottom: 1px solid var(--border);
  }
  th.cb-col, td.cb-col { width: 36px; text-align: center; padding-left: 10px; padding-right: 4px; }
  input[type=checkbox] { width: 15px; height: 15px; cursor: pointer; accent-color: var(--dark); }
  tbody tr { border-bottom: 1px solid var(--border); transition: opacity 0.15s; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr.unchecked { opacity: 0.35; }
  tbody tr.hidden { display: none; }
  td { padding: 9px 14px; font-size: 14px; }
  td.host { font-size: 13px; word-break: break-all; }
  td.host a { color: var(--fg); }
  td.status { font-weight: 600; font-size: 14px; white-space: nowrap; }
  td.mark-col, td.retry-col { width: 56px; text-align: center; padding: 6px 6px; }

  .mark-btn, .retry-btn {
    font-size: 12px; font-weight: 500;
    padding: 2px 8px; border-radius: var(--radius); border: 1.5px solid var(--border);
    background: transparent; cursor: pointer; transition: all 0.15s; color: var(--muted);
  }
  .mark-btn:hover:not(:disabled) { border-color: #1f7a8c; color: #1f7a8c; }
  .mark-btn.marked { border-color: #1f7a8c; background: rgba(31, 122, 140, 0.12); color: #1f7a8c; }
  .retry-btn { font-size: 15px; padding: 1px 7px; }
  .retry-btn:hover { border-color: var(--ring-border); color: var(--fg); }
  .retry-btn:disabled { opacity: 0.3; cursor: default; }

  .s0   { color: var(--border-strong); }
  .s2xx { color: #2f7d4f; }
  .s208 { color: #1f7a8c; }
  .s3xx { color: #b06f2b; }
  .s4xx { color: #9a3b2e; }
  .s5xx { color: #7a2820; }
  .serr { color: var(--muted); }
  .pending { color: var(--muted); }
  .spinner {
    display: inline-block; width: 11px; height: 11px;
    border: 2px solid var(--border); border-top-color: var(--fg);
    border-radius: 50%; animation: dns-spin 0.7s linear infinite; vertical-align: middle;
  }
  @keyframes dns-spin { to { transform: rotate(360deg); } }
</style>

<script>
  const fileInput = document.getElementById('fileInput');
  const dropZone  = document.getElementById('dropZone');
  const startBtn  = document.getElementById('startBtn');
  const clearBtn  = document.getElementById('clearBtn');
  const progress  = document.getElementById('progress');
  const tbody     = document.getElementById('resultBody');
  const filterBar = document.getElementById('filterBar');

  let hosts = [];
  // { code: string, marked: bool } per row
  const rowMeta = [];

  // ── Debounce ───────────────────────────────────────────────────────────────

  function debounce(fn, ms) {
    let t;
    return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), ms); };
  }
  const scheduleBuildFilters = debounce(buildFilters, 150);

  // ── File handling ──────────────────────────────────────────────────────────

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) loadFile(file);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) loadFile(fileInput.files[0]);
  });

  function loadFile(file) {
    const reader = new FileReader();
    reader.onload = e => {
      hosts = parseDNS(e.target.result);
      renderTable(hosts);
      startBtn.disabled = hosts.length === 0;
      progress.textContent = `${hosts.length} entries`;
      filterBar.innerHTML = '';
    };
    reader.readAsText(file, 'UTF-8');
  }

  // ── DNS parser ─────────────────────────────────────────────────────────────

  function parseDNS(text) {
    const seen = new Set();
    const result = [];
    for (const raw of text.split('\n')) {
      const line = raw.trim();
      if (!line || line.startsWith(';') || line.startsWith('#')) continue;
      const col = line.split(/\s+/)[0];
      let host = col.replace(/\.$/, '');
      if (!host || host === '@' || host.startsWith('*')) continue;
      if (!/^[a-zA-Z0-9._-]+$/.test(host)) continue;
      if (!host.includes('.')) continue;
      host = host.toLowerCase();
      if (seen.has(host)) continue;
      seen.add(host);
      result.push(host);
    }
    return result;
  }

  // ── Table render ───────────────────────────────────────────────────────────

  function renderTable(hosts) {
    tbody.innerHTML = '';
    rowMeta.length = 0;
    hosts.forEach((host, i) => {
      rowMeta.push({ code: null, marked: false });
      const tr = document.createElement('tr');
      tr.id = `row-${i}`;
      tr.innerHTML = `
        <td class="cb-col"><input type="checkbox" id="cb-${i}" checked></td>
        <td>${i + 1}</td>
        <td class="host">${escHtml(host)}</td>
        <td class="host"><a href="https://${escHtml(host)}" target="_blank" rel="noopener">https://${escHtml(host)}</a></td>
        <td class="status pending" id="st-${i}">–</td>
        <td class="mark-col"><button class="mark-btn" id="mk-${i}" title="Mark as handled">✓</button></td>
        <td class="retry-col"><button class="retry-btn" id="rt-${i}" title="Retry">↺</button></td>
      `;
      tbody.appendChild(tr);

      document.getElementById(`cb-${i}`).addEventListener('change', e => {
        tr.classList.toggle('unchecked', !e.target.checked);
        updateCheckAll();
      });

      document.getElementById(`mk-${i}`).addEventListener('click', () => toggleMark(i));
      document.getElementById(`rt-${i}`).addEventListener('click', () => retryRow(i));
    });
    document.getElementById('checkAll').checked = true;
    document.getElementById('checkAll').indeterminate = false;
    activeFilter = 'all';
    buildFilters();   // show "All 0" immediately
  }

  function updateCheckAll() {
    const boxes = [...tbody.querySelectorAll('input[type=checkbox]')];
    const all = boxes.every(b => b.checked);
    const none = boxes.every(b => !b.checked);
    const ca = document.getElementById('checkAll');
    ca.checked = all;
    ca.indeterminate = !all && !none;
  }

  document.getElementById('checkAll').addEventListener('change', e => {
    const checked = e.target.checked;
    tbody.querySelectorAll('input[type=checkbox]').forEach(b => { b.checked = checked; });
    tbody.querySelectorAll('tr').forEach(tr => tr.classList.toggle('unchecked', !checked));
  });

  // ── Mark logic ─────────────────────────────────────────────────────────────

  function toggleMark(i) {
    const meta = rowMeta[i];
    meta.marked = !meta.marked;
    const btn = document.getElementById(`mk-${i}`);
    const el  = document.getElementById(`st-${i}`);
    btn.classList.toggle('marked', meta.marked);
    if (meta.marked) {
      el.className = 'status s208';
      el.textContent = '208';
    } else {
      applyStatus(el, meta.code, i);
    }
    // re-apply current filter (208 is its own filter bucket)
    applyFilterToRow(i);
    scheduleBuildFilters();
  }

  function applyStatus(el, code, rowIdx) {
    if (!code) { el.className = 'status pending'; el.textContent = '–'; return; }
    const n = parseInt(code, 10);
    const cls = isNaN(n) ? 'serr' : n >= 500 ? 's5xx' : n >= 400 ? 's4xx' : n >= 300 ? 's3xx' : 's2xx';
    el.className = `status ${cls}`;
    el.textContent = code;
    if (rowIdx !== undefined) {
      const btn = document.getElementById(`mk-${rowIdx}`);
      const is200 = n === 200;
      btn.disabled = is200;
      btn.style.opacity = is200 ? '0.2' : '';
      btn.style.cursor  = is200 ? 'default' : '';
    }
  }

  // displayed code: 208 when marked, otherwise original
  function displayCode(i) {
    return rowMeta[i].marked ? '208' : rowMeta[i].code;
  }

  function applyFilterToRow(i) {
    if (activeFilter === 'all') return;
    const tr = document.getElementById(`row-${i}`);
    tr.classList.toggle('hidden', displayCode(i) !== activeFilter);
  }

  // ── Filter ─────────────────────────────────────────────────────────────────

  let activeFilter = 'all';

  function buildFilters() {
    const counts = {};
    hosts.forEach((_, i) => {
      const c = displayCode(i);
      if (!c) return;
      counts[c] = (counts[c] || 0) + 1;
    });

    const done = hosts.filter((_, i) => displayCode(i)).length;

    // Update existing pills in-place to avoid flicker; rebuild if structure changed
    const existing = [...filterBar.querySelectorAll('.fpill[data-filter]')];
    const existingKeys = existing.map(p => p.dataset.filter);
    const newKeys = ['all', ...Object.keys(counts).sort((a, b) => (parseInt(a)||9999) - (parseInt(b)||9999))];
    const needRebuild = JSON.stringify(existingKeys) !== JSON.stringify(newKeys);

    if (needRebuild) {
      filterBar.innerHTML = '';
      addPill('all', `All ${done}`, 'fpill-all', activeFilter === 'all');
      const sorted = Object.keys(counts).sort((a, b) => (parseInt(a)||9999) - (parseInt(b)||9999));
      sorted.forEach(code => {
        const n = parseInt(code, 10);
        const cls = isNaN(n) ? 'fpill-err' : n >= 500 ? 'fpill-5xx' : n >= 400 ? 'fpill-4xx' : n >= 300 ? 'fpill-3xx' : 'fpill-2xx';
        addPill(code, `${code} ×${counts[code]}`, cls, activeFilter === code);
      });
    } else {
      // in-place update: just refresh label text, no DOM rebuild → no flicker
      filterBar.querySelectorAll('.fpill[data-filter]').forEach(p => {
        const v = p.dataset.filter;
        if (v === 'all') {
          p.querySelector('span').textContent = `All ${done}`;
        } else if (counts[v] !== undefined) {
          p.querySelector('span').textContent = `${v} ×${counts[v]}`;
        }
      });
    }
  }

  function addPill(value, label, cls, active) {
    const btn = document.createElement('button');
    btn.className = `fpill ${cls}${active ? ' active' : ''}`;
    btn.dataset.filter = value;
    btn.innerHTML = `<span>${escHtml(label)}</span>`;
    btn.addEventListener('click', () => applyFilter(value));
    filterBar.appendChild(btn);
  }

  function applyFilter(value) {
    activeFilter = value;
    filterBar.querySelectorAll('.fpill').forEach(p => {
      p.classList.toggle('active', p.dataset.filter === value);
    });
    hosts.forEach((_, i) => {
      const tr = document.getElementById(`row-${i}`);
      tr.classList.toggle('hidden', value !== 'all' && displayCode(i) !== value);
    });
  }

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Check logic ────────────────────────────────────────────────────────────

  const apiBase = () => location.hostname === 'localhost' ? '/api' : 'https://api.ropean.org';

  async function runCheck(host, i) {
    document.getElementById(`rt-${i}`).disabled = true;
    const el = document.getElementById(`st-${i}`);
    el.className = 'status pending';
    el.innerHTML = '<span class="spinner"></span>';
    const apiUrl = `${apiBase()}/request?`
      + new URLSearchParams({ method: 'HEAD', url: `https://${host}`, allowRedirect: 'false' });
    try {
      const res = await fetch(apiUrl);
      if (!res.ok) throw new Error(`API ${res.status}`);
      const json = await res.json();
      const s = json?.response?.statusCode;
      if (!s) throw new Error('no statusCode');
      const code = String(s);
      rowMeta[i].code = code;
      rowMeta[i].marked = false;
      document.getElementById(`mk-${i}`).classList.remove('marked');
      applyStatus(el, code, i);
    } catch (err) {
      rowMeta[i].code = 'Error';
      el.className = 'status serr';
      el.textContent = err.message.slice(0, 40);
    }
    applyFilterToRow(i);
    scheduleBuildFilters();
    document.getElementById(`rt-${i}`).disabled = false;
  }

  async function retryRow(i) {
    await runCheck(hosts[i], i);
  }

  startBtn.addEventListener('click', async () => {
    if (!hosts.length) return;
    startBtn.disabled = true;
    clearBtn.disabled = true;
    activeFilter = 'all';
    buildFilters();

    hosts.forEach((_, i) => {
      rowMeta[i].marked = false;
      document.getElementById(`mk-${i}`).classList.remove('marked');
      document.getElementById(`row-${i}`).classList.remove('hidden');
      const checked = document.getElementById(`cb-${i}`).checked;
      if (checked) {
        rowMeta[i].code = null;
      } else {
        rowMeta[i].code = '0';
        const el = document.getElementById(`st-${i}`);
        el.className = 'status s0';
        el.textContent = '0';
        document.getElementById(`rt-${i}`).disabled = false;
      }
    });

    let done = 0;
    const CONCURRENCY = 5;
    let idx = 0;

    async function worker() {
      while (idx < hosts.length) {
        const i = idx++;
        if (!document.getElementById(`cb-${i}`).checked) continue;
        await runCheck(hosts[i], i);
        done++;
        progress.textContent = `${done} / ${hosts.length}`;
      }
    }

    await Promise.all(Array.from({ length: CONCURRENCY }, worker));

    startBtn.disabled = false;
    clearBtn.disabled = false;
    progress.textContent = `Done ${done} / ${hosts.length}`;
  });

  // ── Clear ──────────────────────────────────────────────────────────────────

  clearBtn.addEventListener('click', () => {
    hosts = [];
    rowMeta.length = 0;
    tbody.innerHTML = '';
    filterBar.innerHTML = '';
    startBtn.disabled = true;
    progress.textContent = '';
    fileInput.value = '';
  });
</script>
