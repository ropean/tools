---
// Icon for a tool card:
//  - external tool → the site's /favicon.svg, falling back to the category icon
//    if it fails to load;
//  - internal tool with an `icon` name → that named icon;
//  - otherwise → the category icon.
import CategoryIcon from './CategoryIcon.astro';

const { tool, size = 20 } = Astro.props;

// Short aliases for common favicon hosts (used via tool.favicon: 'github').
const FAVICON_ALIASES = {
  github: 'https://github.githubassets.com/favicons/favicon.svg',
};

// Favicon candidates, tried in order; on the last failure we fall back to the
// category icon. tool.favicon overrides the URL (a known alias or a full URL).
let favicons = [];
if (tool.favicon) {
  favicons = [FAVICON_ALIASES[tool.favicon] ?? tool.favicon];
} else if (tool.external) {
  try {
    const origin = new URL(tool.external).origin;
    favicons = [origin + '/favicon.svg', origin + '/favicon.ico'];
  } catch { /* bad URL */ }
}

const svg = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': 1.6,
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
};
const name = tool.icon;
---
{favicons.length ? (
  <span class="ti-fav">
    <img src={favicons[0]} data-next={favicons[1] ?? ''} alt="" width={size + 2} height={size + 2} loading="lazy"
         onerror="var n=this.dataset.next; if(n){this.dataset.next='';this.src=n;}else{this.closest('.ti-fav').classList.add('failed');}" />
    <span class="ti-fallback"><CategoryIcon category={tool.category} size={size} /></span>
  </span>
) : name === 'globe' ? (
  <svg {...svg}><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18a15 15 0 0 1 0-18"/></svg>
) : name === 'server' ? (
  <svg {...svg}><rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><line x1="7" y1="7.5" x2="7.01" y2="7.5"/><line x1="7" y1="16.5" x2="7.01" y2="16.5"/></svg>
) : name === 'shield' ? (
  <svg {...svg}><path d="M12 3l7 3v5c0 4.5-3 8-7 10c-4-2-7-5.5-7-10V6z"/></svg>
) : name === 'file' ? (
  <svg {...svg}><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/></svg>
) : name === 'code' ? (
  <svg {...svg}><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M10 12l-2 2 2 2"/><path d="M14 12l2 2-2 2"/></svg>
) : name === 'braces' ? (
  <svg {...svg}><path d="M8 3c-1.5 0-2 1-2 2v3c0 1-1 2-2 2c1 0 2 1 2 2v3c0 1 .5 2 2 2"/><path d="M16 3c1.5 0 2 1 2 2v3c0 1 1 2 2 2c-1 0-2 1-2 2v3c0 1-.5 2-2 2"/></svg>
) : name === 'clock' ? (
  <svg {...svg}><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
) : name === 'shuffle' ? (
  <svg {...svg}><path d="M16 4h4v4"/><path d="M4 20L20 4"/><path d="M4 4l5 5"/><path d="M15 15l5 5"/><path d="M16 20h4v-4"/></svg>
) : name === 'qr' ? (
  <svg {...svg}><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3h-3z"/><path d="M20 14v3"/><path d="M14 20h3"/><path d="M20 20h.01"/></svg>
) : (
  <CategoryIcon category={tool.category} size={size} />
)}
