---
// Base HTML shell: <head>, theme stylesheet, header and footer.
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description = '', current } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script is:inline>
      // Set the theme before first paint to avoid a flash.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <Header current={current} />
      <main style="flex:1;width:100%;">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      // Wire every clearable search input: show the × only when it has a value,
      // clear + refocus + re-fire 'input' (so the field's own listener re-runs).
      for (const btn of document.querySelectorAll('.clear-btn')) {
        const input = btn.parentElement?.querySelector('input');
        if (!input) continue;
        const sync = () => btn.classList.toggle('show', !!input.value);
        input.addEventListener('input', sync);
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          input.value = '';
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.focus();
          sync();
        });
        sync();
      }
    </script>
  </body>
</html>
