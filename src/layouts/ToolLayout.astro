---
// Shared chrome for a single tool page: breadcrumb, "all tools" button,
// tool switcher, and a two-column body (tool UI + sidebar).
// Put the tool's own UI in the default slot. Override the sidebar with
// <Fragment slot="sidebar"> if a tool needs custom side content.
import Base from './Base.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import ToolIcon from '../components/ToolIcon.astro';
import { categoryLabel, groupByCategory, toolHref } from '../data/tools.js';

const heart = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S3.5 15 3.5 8.9C3.5 6.1 5.7 4 8.4 4c1.7 0 3 .8 3.6 2c.6-1.2 1.9-2 3.6-2c2.7 0 4.9 2.1 4.9 4.9c0 6.1-8.5 11.6-8.5 11.6z"/></svg>';

const { tool } = Astro.props;
const catLabel = categoryLabel(tool.category);
// Single sorted source: both the switcher and the related list derive from
// groupByCategory (categories + tools already sorted alphabetically).
const switcherGroups = groupByCategory();
const related = (switcherGroups.find((g) => g.key === tool.category)?.tools ?? [])
  .filter((t) => t.id !== tool.id)
  .slice(0, 5);
---
<Base title={`${tool.name} · QingTools`} description={tool.desc}>
  <div class="tool-page">
    <p class="breadcrumb">
      <a href="/">Home</a> / <a href={`/?category=${tool.category}`}>{catLabel}</a> / {tool.name}
    </p>

    <div class="tool-toolbar">
      <a class="btn" href="/">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        All tools
      </a>

      <div style="position:relative;">
        <button type="button" class="btn btn-ghost" data-switcher-toggle style="gap:10px;">
          <span class="mini-icon"><CategoryIcon category={tool.category} /></span>
          <span style="display:flex;flex-direction:column;align-items:flex-start;">
            <span style="font-size:11px;color:var(--muted);">{catLabel}</span>
            <span style="font-size:15px;font-weight:600;">{tool.name}</span>
          </span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5f5f5d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="switcher" data-switcher hidden style="position:absolute;right:0;top:calc(100% + 8px);width:320px;max-height:420px;overflow-y:auto;background:var(--bg);border:1px solid var(--border);border-radius:12px;box-shadow:rgba(0,0,0,0.1) 0 4px 12px;z-index:41;">
          <div style="padding:12px;border-bottom:1px solid var(--border);">
            <span class="input-clear" style="display:block;">
              <input type="text" class="field" data-switcher-search placeholder="Search tools…" style="padding:8px 32px 8px 10px;font-size:14px;" autocomplete="off" />
              <button type="button" class="clear-btn" aria-label="Clear">×</button>
            </span>
          </div>
          {switcherGroups.map((group) => (
            <div data-switcher-group={group.key}>
              <div style="padding:10px 12px 4px;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">{group.label}</div>
              {group.tools.map((t) => (
                <a
                  class="related-item"
                  href={toolHref(t)}
                  data-switcher-item
                  data-id={t.id}
                  data-search={`${t.name} ${t.desc}`.toLowerCase()}
                  style="padding:9px 12px;"
                  aria-current={t.id === tool.id ? 'page' : undefined}
                  target={t.external ? '_blank' : undefined}
                  rel={t.external ? 'noopener' : undefined}
                >
                  <span class="mini-icon"><ToolIcon tool={t} size={16} /></span>
                  <span class="sw-name">{t.name}</span>
                  {t.external && <span class="sw-ext">↗</span>}
                  <button type="button" class="fav-btn sw-fav" data-fav aria-pressed="false" aria-label="Toggle favorite" set:html={heart}></button>
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="tool-body">
      <div class="tool-main"><slot /></div>
      <div class="tool-side">
        <slot name="sidebar">
          <div class="panel">
            <h3>{tool.name}</h3>
            <p>{tool.desc}</p>
          </div>
          {related.length > 0 && (
            <div class="panel">
              <h3 style="margin-bottom:12px;">Related tools</h3>
              <div class="related-list">
                {related.map((rt) => (
                  <a
                    class="related-item"
                    href={toolHref(rt)}
                    target={rt.external ? '_blank' : undefined}
                    rel={rt.external ? 'noopener' : undefined}
                  >
                    <span class="mini-icon"><ToolIcon tool={rt} size={16} /></span>
                    <span class="sw-name">{rt.name}</span>
                    {rt.external && <span class="sw-ext">↗</span>}
                  </a>
                ))}
              </div>
            </div>
          )}
        </slot>
      </div>
    </div>
  </div>
</Base>

<style>
  .related-item .sw-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .related-item .sw-ext { color: var(--muted); font-size: 11px; flex: 0 0 auto; }
  .related-item .sw-fav { flex: 0 0 auto; width: 24px; height: 24px; }
</style>

<script>
  // Tool switcher: open/close, close on outside click, filter by text.
  const toggle = document.querySelector('[data-switcher-toggle]');
  const panel = document.querySelector('[data-switcher]');
  const searchInput = document.querySelector('[data-switcher-search]');
  const items = Array.from(document.querySelectorAll('[data-switcher-item]'));
  const groups = Array.from(document.querySelectorAll('[data-switcher-group]'));

  function close() { if (panel) panel.hidden = true; }

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (panel) {
      panel.hidden = !panel.hidden;
      if (!panel.hidden) searchInput?.focus();
    }
  });

  document.addEventListener('click', (e) => {
    if (panel && !panel.hidden && !panel.contains(e.target) && !toggle?.contains(e.target)) close();
  });

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    for (const item of items) {
      item.hidden = q && !(item.dataset.search || '').includes(q);
    }
    for (const group of groups) {
      group.hidden = !group.querySelector('[data-switcher-item]:not([hidden])');
    }
  });

  // Favorite hearts inside the switcher (shared 'favorites' localStorage key).
  const FAV_KEY = 'favorites';
  function loadFavs() {
    try {
      const a = JSON.parse(localStorage.getItem(FAV_KEY) || '[]');
      return new Set(Array.isArray(a) ? a : []);
    } catch { return new Set(); }
  }
  let favs = loadFavs();
  function syncSwitcherHearts() {
    for (const btn of document.querySelectorAll('[data-switcher-item] [data-fav]')) {
      const id = btn.closest('[data-switcher-item]').dataset.id;
      btn.setAttribute('aria-pressed', favs.has(id) ? 'true' : 'false');
    }
  }
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-switcher-item] [data-fav]');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    const id = btn.closest('[data-switcher-item]').dataset.id;
    if (favs.has(id)) favs.delete(id); else favs.add(id);
    try { localStorage.setItem(FAV_KEY, JSON.stringify([...favs])); } catch { /* private mode */ }
    syncSwitcherHearts();
  });
  syncSwitcherHearts();
</script>
